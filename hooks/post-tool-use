#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

HOOK_INPUT=$(cat)

# Fast-path: only care about Bash tool calls containing "git commit"
COMMAND=$(echo "$HOOK_INPUT" | python3 -c \
  "import sys,json; d=json.load(sys.stdin); print(d.get('tool_input',{}).get('command',''))" \
  2>/dev/null || echo "")

if ! echo "$COMMAND" | grep -qF "git commit"; then
  exit 0
fi

SESSION_ID=$(echo "$HOOK_INPUT" | python3 -c \
  "import sys,json; d=json.load(sys.stdin); print(d.get('session_id',''))" \
  2>/dev/null || echo "")

if [ -z "$SESSION_ID" ]; then
  exit 0
fi

# Config check — only track if configured
CONFIG_DIR="${CLAUDE_JIRA_CONFIG_DIR:-${HOME}/.claude-jira}"
if [ ! -f "${CONFIG_DIR}/config.json" ]; then
  exit 0
fi

# Track commit (async — don't block Claude's response)
bun run "${PLUGIN_ROOT}/src/cli.ts" post-commit --session "$SESSION_ID" 2>/dev/null || true

exit 0
