#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

HOOK_INPUT=$(cat)
SESSION_ID=$(echo "$HOOK_INPUT" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('session_id',''))" 2>/dev/null || echo "")

if [ -z "$SESSION_ID" ]; then
  exit 0
fi

# Check if session has tracked commits
SESSION_FILE="${HOME}/.claude-jira/sessions/${SESSION_ID}.json"
if [ ! -f "$SESSION_FILE" ]; then
  exit 0
fi

COMMIT_COUNT=$(python3 -c "import sys,json; d=json.load(open('${SESSION_FILE}')); print(len(d.get('commits',[])))" 2>/dev/null || echo "0")

if [ "$COMMIT_COUNT" = "0" ]; then
  exit 0
fi

escape_for_json() {
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  s="${s//$'\n'/\\n}"
  printf '%s' "$s"
}

context="<jira-suggestion>\nThis session included ${COMMIT_COUNT} commit(s). Consider updating your Jira ticket: say 'update jira' or use /jira to add a comment or change the status.\n</jira-suggestion>"
escaped=$(escape_for_json "$context")

if [ -n "${CLAUDE_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "Stop",\n    "additionalContext": "%s"\n  }\n}\n' "$escaped"
fi

exit 0
