#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

HOOK_INPUT=$(cat)
SESSION_ID=$(echo "$HOOK_INPUT" | python3 -c \
  "import sys,json; d=json.load(sys.stdin); print(d.get('session_id',''))" \
  2>/dev/null || echo "")

if [ -z "$SESSION_ID" ]; then
  exit 0
fi

# Config check
CONFIG_DIR="${CLAUDE_JIRA_CONFIG_DIR:-${HOME}/.claude-jira}"
if [ ! -f "${CONFIG_DIR}/config.json" ]; then
  exit 0
fi

# Check if session has tracked commits
SESSION_FILE="${CONFIG_DIR}/sessions/${SESSION_ID}.json"
if [ ! -f "$SESSION_FILE" ]; then
  exit 0
fi

COMMIT_COUNT=$(python3 -c \
  "import json; d=json.load(open('${SESSION_FILE}')); print(len(d.get('commits',[])))" \
  2>/dev/null || echo "0")

if [ "$COMMIT_COUNT" = "0" ]; then
  exit 0
fi

# Get session summary from CLI (includes suggestion if ticket associated)
SUMMARY=$(bun run "${PLUGIN_ROOT}/src/cli.ts" session-summary --session "$SESSION_ID" 2>/dev/null || echo "")

if [ -z "$SUMMARY" ]; then
  exit 0
fi

escape_for_json() {
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  s="${s//$'\n'/\\n}"
  s="${s//$'\r'/\\r}"
  s="${s//$'\t'/\\t}"
  printf '%s' "$s"
}

context="<jira-session-summary>\n${SUMMARY}\n\nConsider updating Jira: say 'update jira' or use /jira.\n</jira-session-summary>"
escaped=$(escape_for_json "$context")

if [ -n "${CLAUDE_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "Stop",\n    "additionalContext": "%s"\n  }\n}\n' "$escaped"
fi

exit 0
